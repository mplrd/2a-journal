# Admin SPA env. Build-time only (Vite injects VITE_* vars at compile).
# In Railway, set these on the admin service.

# Where the admin SPA hits the API.
#  - Default in code is `/api` (relative), works when the SPA and the API share
#    the same origin (Apache vhost with /api alias, or unified Railway service).
#  - Override here only when the SPA and the API live on separate origins.
# Examples:
#   Prod: VITE_API_URL=https://api.2a-trading-tools.com
#   Vite dev server hitting the local Apache api: VITE_API_URL=http://2a.journal.local/api
# VITE_API_URL=
