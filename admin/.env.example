# Admin SPA env. Build-time only (Vite injects VITE_* vars at compile).
# In Railway, set these on the admin service.

# Where the admin SPA hits the API. In prod, point to api.2a-trading-tools.com (or
# whatever your api domain is). Default below works for local dev with Apache vhost.
VITE_API_URL=http://2a.journal.local/api
