APP_ENV=local
APP_DEBUG=true
APP_URL=http://journal.2ai-tools.local

DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=2ai_tools_journal
DB_USER=root
DB_PASSWORD=

JWT_SECRET=change-me-to-a-random-string

CORS_ORIGINS=http://localhost:5173

# Email — driver: log (default, writes to stderr) or resend (Resend API)
MAIL_ENABLED=false
MAIL_DRIVER=log
MAIL_FROM_ADDRESS=noreply@2a-journal.local
MAIL_FROM_NAME=Trading Journal
# Required when MAIL_DRIVER=resend
# RESEND_API_KEY=re_xxxx

# Refresh token cookie — adjust for cross-origin deployments (e.g. Railway)
# REFRESH_COOKIE_PATH: must match the URL path the browser uses to reach auth endpoints
#   Local (behind /api alias): /api/auth (default)
#   Railway (API on its own domain): /auth
REFRESH_COOKIE_PATH=/api/auth
# REFRESH_COOKIE_SAMESITE: Lax (same-origin) or None (cross-origin, requires Secure)
REFRESH_COOKIE_SAMESITE=Lax
# REFRESH_COOKIE_SECURE: true when served over HTTPS
REFRESH_COOKIE_SECURE=false

# Broker connectors (cTrader, MetaApi)
# BROKER_ENCRYPTION_KEY: REQUIRED. Used to symmetrically encrypt broker credentials
# at rest in broker_connections.credentials_encrypted. Must be identical on the
# api and scheduler services. Generate with: openssl rand -base64 32
BROKER_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32
# BROKER_AUTO_SYNC_ENABLED: master kill switch for both the api endpoints and the scheduler
BROKER_AUTO_SYNC_ENABLED=false
# BROKER_SYNC_INTERVAL_MINUTES: min minutes between two auto-syncs of the same connection (scheduler only)
BROKER_SYNC_INTERVAL_MINUTES=15
# BROKER_SYNC_MAX_FAILURES: connection flipped to ERROR after N consecutive failed syncs (scheduler only)
BROKER_SYNC_MAX_FAILURES=3
